rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * EduVault Security Rules
     *
     * CORE PHILOSOPHY:
     * This ruleset enforces a strict user-ownership model for personal data while maintaining 
     * a public, read-only posture for academic content. It prioritizes "Authorization 
     * Independence" by utilizing path-based wildcards and denormalized fields.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    function isFieldImmutable(fieldName) {
      return request.resource.data[fieldName] == resource.data[fieldName];
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && isFieldImmutable('id');
      allow delete: if isExistingOwner(userId);

      match /savedMaterials/{userSavedMaterialId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && isFieldImmutable('userId');
        allow delete: if isExistingOwner(userId);
      }

      match /quizAttempts/{userQuizAttemptId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if false;
        allow delete: if isExistingOwner(userId);
      }
    }

    match /classes/{classId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    match /subjects/{subjectId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    match /chapters/{chapterId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    match /studyMaterials/{studyMaterialId} {
      allow get, list: if true;
      // Gate creation behind authentication (admin mode)
      allow create: if isSignedIn();
      allow update, delete: if false; 
    }

    match /competitiveExams/{competitiveExamId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    match /competitiveExamMaterials/{competitiveExamMaterialId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /quizzes/{quizId} {
      allow get, list: if true;
      allow create, update, delete: if false;

      match /questions/{questionId} {
        allow get, list: if true;
        allow create, update, delete: if false;
      }
    }
  }
}